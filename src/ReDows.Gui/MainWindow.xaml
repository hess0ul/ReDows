<Window x:Class="ReDows.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ReDows" Height="720" Width="1120"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource App.Background}"
        FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource App.Surface}" Padding="22,16"
                BorderBrush="{StaticResource App.Border}" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="ReDows" FontSize="20" FontWeight="SemiBold"/>
                <TextBlock Text="Inventory &amp; backup before a Windows reset — read-only on your PC."
                           Foreground="{StaticResource App.Muted}" FontSize="12" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource App.Surface}"
                    BorderBrush="{StaticResource App.Border}" BorderThickness="0,0,1,0">
                <StackPanel Margin="0,10,0,0">
                    <Button Content="Home" Style="{StaticResource NavButton}" Command="{Binding ShowHomeCommand}"/>
                    <Button Content="Scan" Style="{StaticResource NavButton}" Command="{Binding ShowScanCommand}"/>
                    <Button Content="Review" Style="{StaticResource NavButton}" Command="{Binding ShowReviewCommand}"/>
                    <Button Content="Backup" Style="{StaticResource NavButton}" Command="{Binding ShowBackupCommand}"/>
                    <Button Content="Restore" Style="{StaticResource NavButton}" Command="{Binding ShowRestoreCommand}"/>
                    <Button Content="Apps" Style="{StaticResource NavButton}" IsEnabled="False"/>
                    <Button Content="Settings" Style="{StaticResource NavButton}" IsEnabled="False"/>
                    <Button Content="Secrets" Style="{StaticResource NavButton}" IsEnabled="False"/>
                    <TextBlock Text="More screens coming next." Foreground="{StaticResource App.Muted}"
                               FontSize="11" Margin="18,12,10,0"/>
                </StackPanel>
            </Border>

            <ContentControl Grid.Column="1" Content="{Binding CurrentViewModel}"/>
        </Grid>
    </Grid>
</Window>
