<UserControl x:Class="ReDows.Gui.Views.RestoreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="26,22" MaxWidth="920" HorizontalAlignment="Left">
            <TextBlock Text="Restore" FontSize="18" FontWeight="SemiBold"/>
            <TextBlock Text="Put a backup back — the reverse of Backup. Nothing is overwritten or deleted: files that already exist are kept."
                       Foreground="{StaticResource App.Muted}" Margin="0,4,0,16"/>

            <!-- Backup folder -->
            <Border Background="{StaticResource App.Card}" CornerRadius="8" Padding="16"
                    BorderBrush="{StaticResource App.Border}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Backup to restore" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding BackupFolder, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="1" Content="Browse…" Style="{StaticResource GhostButton}"
                                Margin="8,0,0,0" Click="BrowseBackup_Click"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Destination -->
            <Border Background="{StaticResource App.Card}" CornerRadius="8" Padding="16" Margin="0,12,0,0"
                    BorderBrush="{StaticResource App.Border}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Where to restore" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton GroupName="dest" Content="Original locations" IsChecked="{Binding ToOriginalLocations, Mode=TwoWay}"/>
                        <RadioButton GroupName="dest" Content="A folder…"
                                     IsChecked="{Binding ToOriginalLocations, Converter={StaticResource Not}, Mode=TwoWay}"/>
                    </StackPanel>
                    <TextBlock Margin="0,6,0,0" Foreground="{StaticResource App.Muted}" FontSize="12" TextWrapping="Wrap"
                               Text="“Original locations” puts each file back where it came from (a real restore after a reset). “A folder” rebuilds the tree under a folder you pick, so you can inspect or move things yourself."/>
                    <Grid Margin="0,10,0,0" IsEnabled="{Binding ToOriginalLocations, Converter={StaticResource Not}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding TargetFolder, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="1" Content="Browse…" Style="{StaticResource GhostButton}"
                                Margin="8,0,0,0" Click="BrowseTarget_Click"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Secrets -->
            <Border Background="{StaticResource App.Card}" CornerRadius="8" Padding="16" Margin="0,12,0,0"
                    BorderBrush="{StaticResource App.Border}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Secrets vault password (optional)" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource App.Muted}" FontSize="12" Margin="0,0,0,8"
                               Text="If this backup has a secrets vault (secrets-vault.zip), enter its password to restore your passwords and keys back to their places. Leave empty to skip them — you can always open the vault yourself with 7-Zip or WinRAR."/>
                    <PasswordBox x:Name="VaultPassword" Width="280" HorizontalAlignment="Left" Padding="8,6"
                                 Background="{StaticResource App.Surface}" Foreground="White"
                                 BorderBrush="{StaticResource App.Border}" CaretBrush="White"/>
                </StackPanel>
            </Border>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                <Button Content="Restore" Click="Run_Click" IsEnabled="{Binding CanRun}"/>
                <Button Content="Cancel" Style="{StaticResource GhostButton}" Command="{Binding CancelCommand}" Margin="10,0,0,0"/>
            </StackPanel>

            <!-- Progress -->
            <StackPanel Margin="0,14,0,0" Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}">
                <ProgressBar IsIndeterminate="True" Height="4" BorderThickness="0"
                             Foreground="{StaticResource App.Accent}" Background="{StaticResource App.Card}"/>
                <TextBlock Text="{Binding ProgressText}" Foreground="{StaticResource App.Muted}" FontSize="12"
                           Margin="0,6,0,0" TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <!-- Error -->
            <Border Background="#3A2A2A" CornerRadius="6" Padding="12,10" Margin="0,14,0,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Error}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding Error}" Foreground="#FF9B9B"/>
            </Border>

            <!-- Result -->
            <StackPanel Margin="0,18,0,0">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Result}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <UniformGrid Rows="1" Columns="3">
                    <Border Background="{StaticResource App.Card}" CornerRadius="8" Padding="14" Margin="0,0,8,0"
                            BorderBrush="{StaticResource App.Border}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Restored" Foreground="{StaticResource App.Good}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Result.RestoredText}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource App.Card}" CornerRadius="8" Padding="14" Margin="4,0,4,0"
                            BorderBrush="{StaticResource App.Border}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Already there (kept)" Foreground="{StaticResource App.Muted}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Result.SkippedText}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource App.Card}" CornerRadius="8" Padding="14" Margin="8,0,0,0"
                            BorderBrush="{StaticResource App.Border}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Failed" Foreground="{StaticResource App.Muted}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Result.FailedText}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Checksum verification (only when the backup carried a hash manifest) -->
                <TextBlock Margin="0,10,0,0" Foreground="{StaticResource App.Good}" FontSize="12" TextWrapping="Wrap"
                           Text="{Binding Result.VerifiedText}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Result.VerifiedText}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock Margin="0,10,0,0" Foreground="{StaticResource App.Muted}" FontSize="12" TextWrapping="Wrap">
                    <Run Text="Secrets: "/><Run Text="{Binding Result.SecretsText, Mode=OneWay}"/>
                </TextBlock>

                <TextBlock Text="Could not restore (reported, never silently dropped)" FontWeight="SemiBold"
                           Foreground="#E8C97A" Margin="0,16,0,6">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Result.TopFailures.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <ItemsControl ItemsSource="{Binding Result.TopFailures}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource App.Card}" CornerRadius="6" Padding="10,6" Margin="0,0,0,4"
                                    BorderBrush="{StaticResource App.Border}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{Binding Path}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Reason}" Foreground="{StaticResource App.Muted}" FontSize="11"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
