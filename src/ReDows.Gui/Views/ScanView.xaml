<UserControl x:Class="ReDows.Gui.Views.ScanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="26,22" MaxWidth="920" HorizontalAlignment="Left">
            <TextBlock Text="Scan" FontSize="18" FontWeight="SemiBold"/>
            <TextBlock Text="Walk your PC (read-only) and sort every file: to keep, to review, or safe to ignore."
                       Foreground="{StaticResource App.Muted}" Margin="0,4,0,16"/>

            <!-- Options -->
            <Border Background="{StaticResource App.Card}" CornerRadius="8" Padding="16"
                    BorderBrush="{StaticResource App.Border}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="What to scan" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton GroupName="scope" Content="Whole PC" IsChecked="{Binding WholePc, Mode=TwoWay}"/>
                        <RadioButton GroupName="scope" Content="A folder…"
                                     IsChecked="{Binding WholePc, Converter={StaticResource Not}, Mode=TwoWay}"/>
                    </StackPanel>
                    <Grid Margin="0,10,0,0" IsEnabled="{Binding WholePc, Converter={StaticResource Not}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding FolderPath, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="1" Content="Browse…" Style="{StaticResource GhostButton}"
                                Margin="8,0,0,0" Click="Browse_Click"/>
                    </Grid>

                    <CheckBox Content="Recognize installed apps (re-downloadable)" FontWeight="SemiBold" Margin="0,16,0,0"
                              IsChecked="{Binding RecognizeInstalledApps, Mode=TwoWay}"/>
                    <TextBlock Margin="24,4,0,0" Foreground="{StaticResource App.Muted}" FontSize="12" TextWrapping="Wrap"
                               Text="Install folders of apps this PC has are treated as re-downloadable and moved out of review; each app's settings are kept and its local data surfaced for review. Only affects files the scan would otherwise review — a keep or a secret is never touched."/>
                </StackPanel>
            </Border>

            <!-- Category options (optional): bulk-decide whole file types -->
            <Expander Margin="0,12,0,0" Header="Category options — bulk-decide whole file types (optional)">
                <Border Background="{StaticResource App.Card}" CornerRadius="8" Padding="14" Margin="0,8,0,0"
                        BorderBrush="{StaticResource App.Border}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource App.Muted}" FontSize="12" Margin="0,0,0,10"
                                   Text="Every category starts on “review”. Set one to Keep or Ignore to bulk-classify scattered files of that type. This only affects files the scan would otherwise review — a keep, a secret, or a save-named folder is never touched."/>
                        <ItemsControl ItemsSource="{Binding Modules}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center"
                                                   FontSize="14" TextTrimming="CharacterEllipsis" Margin="0,0,8,0"/>
                                        <Border Grid.Column="1" Width="18" Height="18" CornerRadius="9" Margin="0,0,16,0"
                                                VerticalAlignment="Center" Cursor="Help"
                                                Background="{StaticResource App.Surface}" BorderBrush="{StaticResource App.Border}" BorderThickness="1"
                                                ToolTipService.InitialShowDelay="200" ToolTipService.ShowDuration="30000">
                                            <Border.ToolTip>
                                                <TextBlock Text="{Binding Detects}" TextWrapping="Wrap" MaxWidth="360"/>
                                            </Border.ToolTip>
                                            <TextBlock Text="?" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource App.Muted}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                                            <RadioButton Content="Keep" GroupName="{Binding Name}" FontSize="14"
                                                         Padding="8,6" MinWidth="80" Margin="0,0,14,0" VerticalContentAlignment="Center"
                                                         IsChecked="{Binding IsKeep, Mode=TwoWay}"/>
                                            <RadioButton Content="Review" GroupName="{Binding Name}" FontSize="14"
                                                         Padding="8,6" MinWidth="86" Margin="0,0,14,0" VerticalContentAlignment="Center"
                                                         IsChecked="{Binding IsReview, Mode=TwoWay}"/>
                                            <RadioButton Content="Ignore" GroupName="{Binding Name}" FontSize="14"
                                                         Padding="8,6" MinWidth="80" VerticalContentAlignment="Center"
                                                         IsChecked="{Binding IsIgnore, Mode=TwoWay}"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Expander>

            <!-- Duplicate files (optional) -->
            <Border Background="{StaticResource App.Card}" CornerRadius="8" Padding="16" Margin="0,12,0,0"
                    BorderBrush="{StaticResource App.Border}" BorderThickness="1">
                <StackPanel>
                    <CheckBox Content="Also find duplicate files (read-only)" FontWeight="SemiBold"
                              IsChecked="{Binding FindDuplicates, Mode=TwoWay}"/>
                    <StackPanel Margin="24,8,0,0" Visibility="{Binding FindDuplicates, Converter={StaticResource BoolToVis}}">
                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource App.Muted}" FontSize="12" Margin="0,0,0,8"
                                   Text="For each set of byte-identical files, the most recent copy is the one to keep; the other locations are noted so a restore can put it back anywhere. A slower extra pass — and nothing is ever deleted."/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="All files" GroupName="dupmode" Margin="0,0,16,0"
                                         IsChecked="{Binding DuplicatesGlobal, Mode=TwoWay}"/>
                            <RadioButton Content="Only certain types" GroupName="dupmode"
                                         IsChecked="{Binding DuplicatesGlobal, Converter={StaticResource Not}, Mode=TwoWay}"/>
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding Modules}" Margin="0,10,0,0">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DuplicatesGlobal}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Label}" FontSize="13" Margin="0,3"
                                              IsChecked="{Binding DedupeSelected, Mode=TwoWay}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                <Button Content="Run scan" Command="{Binding RunCommand}"/>
                <Button Content="Cancel" Style="{StaticResource GhostButton}" Command="{Binding CancelCommand}" Margin="10,0,0,0"/>
            </StackPanel>

            <!-- Progress -->
            <StackPanel Margin="0,14,0,0" Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}">
                <ProgressBar IsIndeterminate="True" Height="4" BorderThickness="0"
                             Foreground="{StaticResource App.Accent}" Background="{StaticResource App.Card}"/>
                <TextBlock Text="{Binding ProgressText}" Foreground="{StaticResource App.Muted}" FontSize="12"
                           Margin="0,6,0,0" TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <!-- Error -->
            <Border Background="#3A2A2A" CornerRadius="6" Padding="12,10" Margin="0,14,0,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Error}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding Error}" Foreground="#FF9B9B"/>
            </Border>

            <!-- Results -->
            <StackPanel Margin="0,18,0,0">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Result}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <Border Background="#3A331F" CornerRadius="6" Padding="12,8" Margin="0,0,0,12">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Result.Partial}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="Interrupted before the end — the figures below cover only what was scanned."
                               Foreground="#E8C97A"/>
                </Border>

                <UniformGrid Rows="1" Columns="3">
                    <Border Background="{StaticResource App.Card}" CornerRadius="8" Padding="14" Margin="0,0,8,0"
                            BorderBrush="{StaticResource App.Border}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="To keep" Foreground="{StaticResource App.Good}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Result.KeepText}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource App.Card}" CornerRadius="8" Padding="14" Margin="4,0,4,0"
                            BorderBrush="{StaticResource App.Border}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="To review" Foreground="{StaticResource App.Accent}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Result.ReviewText}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource App.Card}" CornerRadius="8" Padding="14" Margin="8,0,0,0"
                            BorderBrush="{StaticResource App.Border}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Ignored" Foreground="{StaticResource App.Muted}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Result.IgnoreText}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <TextBlock Margin="0,10,0,0" Foreground="{StaticResource App.Muted}" FontSize="12">
                    <Run Text="{Binding Result.NoteText, Mode=OneWay}"/><Run Text=" noted (links / reparse points — not copied)."/>
                </TextBlock>

                <Border Background="{StaticResource App.Card}" CornerRadius="6" Padding="12,8" Margin="0,10,0,0"
                        BorderBrush="{StaticResource App.Border}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Total accounting — nothing left uncounted" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Text="{Binding Result.EquationText}" Foreground="{StaticResource App.Muted}"
                                   FontSize="12" Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Recognized installed apps: what that saved you from reviewing by hand (shown only when the option ran) -->
                <Border Background="{StaticResource App.Card}" CornerRadius="6" Padding="12,10" Margin="0,10,0,0"
                        BorderBrush="{StaticResource App.Border}" BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Result.InstalledApps}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" FontSize="12">
                            <Run Text="Recognized "/><Run Text="{Binding Result.InstalledApps.Apps, Mode=OneWay}"/><Run Text=" installed apps"/>
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource App.Muted}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap">
                            <Run Text="Install folders ignored as re-downloadable: "/><Run Text="{Binding Result.InstalledApps.IgnoredText, Mode=OneWay}" Foreground="{StaticResource App.Good}" FontWeight="SemiBold"/>
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource App.Muted}" FontSize="12" Margin="0,2,0,0" TextWrapping="Wrap">
                            <Run Text="App settings kept: "/><Run Text="{Binding Result.InstalledApps.KeptText, Mode=OneWay}" Foreground="{StaticResource App.Good}" FontWeight="SemiBold"/><Run Text="   ·   local app data surfaced for review: "/><Run Text="{Binding Result.InstalledApps.SurfacedText, Mode=OneWay}" Foreground="{StaticResource App.Good}" FontWeight="SemiBold"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Margin="0,14,0,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Result.Alerts.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="⚠ Export these BEFORE the reset (locked to this PC — unreadable after)"
                                   Foreground="#E8C97A" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <ItemsControl ItemsSource="{Binding Result.Alerts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                        <TextBlock Text="{Binding Items}" Foreground="{StaticResource App.Muted}" Width="90"/>
                                        <TextBlock Text="{Binding Rule}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <TextBlock Text="Biggest things to review" FontWeight="SemiBold" Margin="0,16,0,8"/>
                <ItemsControl ItemsSource="{Binding Result.TopReview}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource App.Card}" CornerRadius="6" Padding="12,8" Margin="0,0,0,6"
                                    BorderBrush="{StaticResource App.Border}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Size}" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Items}" Foreground="{StaticResource App.Muted}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Folder}" TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Duplicate files (shown only when the optional pass ran) -->
                <StackPanel Margin="0,20,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Result.Duplicates}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Duplicate files" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock Foreground="{StaticResource App.Muted}" FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap">
                        <Run Text="{Binding Result.Duplicates.Groups, Mode=OneWay}"/><Run Text=" groups · "/><Run Text="{Binding Result.Duplicates.Reclaimable, Mode=OneWay}"/><Run Text=" reclaimable if one copy of each is kept (nothing is deleted)."/>
                    </TextBlock>
                    <ItemsControl ItemsSource="{Binding Result.Duplicates.Top}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource App.Card}" CornerRadius="6" Padding="12,8" Margin="0,0,0,6"
                                        BorderBrush="{StaticResource App.Border}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock>
                                            <Run Text="{Binding Reclaimable, Mode=OneWay}" FontWeight="SemiBold"/><Run Text=" · "/><Run Text="{Binding Copies, Mode=OneWay}"/><Run Text=" copies · "/><Run Text="{Binding SizeEach, Mode=OneWay}"/><Run Text=" each"/>
                                        </TextBlock>
                                        <TextBlock Foreground="{StaticResource App.Good}" FontSize="12" Margin="0,4,0,0" TextTrimming="CharacterEllipsis">
                                            <Run Text="keep (most recent): "/><Run Text="{Binding KeepPath, Mode=OneWay}"/>
                                        </TextBlock>
                                        <ItemsControl ItemsSource="{Binding OtherPaths}" Margin="0,2,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" Foreground="{StaticResource App.Muted}" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Something to review → go to Review; nothing to review → skip straight to Backup. -->
                <Button Content="Review these →" Margin="0,20,0,0" HorizontalAlignment="Left"
                        Command="{Binding DataContext.ShowReviewCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasReview}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="Back up what I'm keeping →" Margin="0,20,0,0" HorizontalAlignment="Left"
                        Command="{Binding DataContext.ShowBackupCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasReview}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
