<UserControl x:Class="ReDows.Gui.Views.BackupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="26,22" MaxWidth="920" HorizontalAlignment="Left">
            <TextBlock Text="Backup" FontSize="18" FontWeight="SemiBold"/>
            <TextBlock Text="Copy the files your last scan marked to keep to a safe place — read-only on your PC, every file verified."
                       Foreground="{StaticResource App.Muted}" Margin="0,4,0,16"/>

            <!-- What gets backed up -->
            <Border Background="{StaticResource App.Card}" CornerRadius="8" Padding="16"
                    BorderBrush="{StaticResource App.Border}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="What gets backed up" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock Foreground="{StaticResource App.Good}" TextWrapping="Wrap"
                               Text="The files your last scan marked to keep (config + user files). Secrets go to the encrypted vault below.">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasManifest}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Foreground="#E8C97A" TextWrapping="Wrap"
                               Text="Nothing to back up yet — run a scan first (Scan tab), then come back here.">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasManifest}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding ManifestPath}" Foreground="{StaticResource App.Muted}" FontSize="11"
                               Margin="0,6,0,0" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>

            <!-- Destination -->
            <Border Background="{StaticResource App.Card}" CornerRadius="8" Padding="16" Margin="0,12,0,0"
                    BorderBrush="{StaticResource App.Border}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Where to save" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock Text="A folder, a USB key, or a network share (\\server\share)."
                               Foreground="{StaticResource App.Muted}" FontSize="12" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding Destination, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="1" Content="Browse…" Style="{StaticResource GhostButton}"
                                Margin="8,0,0,0" Click="Browse_Click"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Secrets vault -->
            <Border Background="{StaticResource App.Card}" CornerRadius="8" Padding="16" Margin="0,12,0,0"
                    BorderBrush="{StaticResource App.Border}" BorderThickness="1">
                <StackPanel>
                    <CheckBox Content="Protect passwords &amp; keys in an encrypted vault" FontWeight="SemiBold"
                              IsChecked="{Binding UseVault, Mode=TwoWay}"/>
                    <StackPanel Margin="24,8,0,0" Visibility="{Binding UseVault, Converter={StaticResource BoolToVis}}">
                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource App.Muted}" FontSize="12" Margin="0,0,0,8"
                                   Text="Secrets go into a password-protected ZIP (AES-256) you can open with 7-Zip or WinRAR on any PC — so they survive the reset. Choose a password you will remember: it is NOT stored anywhere."/>
                        <PasswordBox x:Name="VaultPassword" Width="280" HorizontalAlignment="Left" Padding="8,6"
                                     Background="{StaticResource App.Surface}" Foreground="White"
                                     BorderBrush="{StaticResource App.Border}" CaretBrush="White"/>
                    </StackPanel>
                    <TextBlock Margin="0,8,0,0" Foreground="{StaticResource App.Muted}" FontSize="12" TextWrapping="Wrap"
                               Text="Without a password, secrets are counted but never copied (they are never written in clear).">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding UseVault}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Locked files (VSS) -->
            <Border Background="{StaticResource App.Card}" CornerRadius="8" Padding="16" Margin="0,12,0,0"
                    BorderBrush="{StaticResource App.Border}" BorderThickness="1">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <CheckBox Content="Rescue files that are open in another app" FontWeight="SemiBold"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding UseVss, Mode=TwoWay}" IsEnabled="{Binding IsElevated}"/>
                        <!-- Non-clickable badge: the feature is locked until ReDows runs as administrator. -->
                        <Border Margin="10,0,0,0" Padding="8,2" CornerRadius="10" VerticalAlignment="Center"
                                Background="{StaticResource App.Surface}" BorderBrush="{StaticResource App.Border}" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsElevated}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="🔒 Locked" FontSize="11" Foreground="{StaticResource App.Muted}"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Margin="24,6,0,0" Foreground="{StaticResource App.Muted}" FontSize="12" TextWrapping="Wrap"
                               Text="A locked file is read from a frozen snapshot of the disk (VSS) so it is not lost. Needs administrator rights.">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsElevated}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Margin="24,6,0,0" Foreground="#E8C97A" FontSize="12" TextWrapping="Wrap"
                               Text="Run ReDows as administrator to rescue locked files. Otherwise they are reported, never silently skipped.">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsElevated}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                <Button Content="Back up now" Click="Run_Click" IsEnabled="{Binding CanRun}"/>
                <Button Content="Cancel" Style="{StaticResource GhostButton}" Command="{Binding CancelCommand}" Margin="10,0,0,0"/>
            </StackPanel>

            <!-- Progress -->
            <StackPanel Margin="0,14,0,0" Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}">
                <ProgressBar IsIndeterminate="True" Height="4" BorderThickness="0"
                             Foreground="{StaticResource App.Accent}" Background="{StaticResource App.Card}"/>
                <TextBlock Text="{Binding ProgressText}" Foreground="{StaticResource App.Muted}" FontSize="12"
                           Margin="0,6,0,0" TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <!-- Error -->
            <Border Background="#3A2A2A" CornerRadius="6" Padding="12,10" Margin="0,14,0,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Error}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding Error}" Foreground="#FF9B9B"/>
            </Border>

            <!-- Result -->
            <StackPanel Margin="0,18,0,0">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Result}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <UniformGrid Rows="1" Columns="3">
                    <Border Background="{StaticResource App.Card}" CornerRadius="8" Padding="14" Margin="0,0,8,0"
                            BorderBrush="{StaticResource App.Border}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Copied &amp; verified" Foreground="{StaticResource App.Good}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Result.CopiedText}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource App.Card}" CornerRadius="8" Padding="14" Margin="4,0,4,0"
                            BorderBrush="{StaticResource App.Border}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Secrets → vault" Foreground="{StaticResource App.Accent}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Result.VaultedText}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource App.Card}" CornerRadius="8" Padding="14" Margin="8,0,0,0"
                            BorderBrush="{StaticResource App.Border}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Failed" Foreground="{StaticResource App.Muted}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Result.FailedText}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <TextBlock Margin="0,10,0,0" Foreground="{StaticResource App.Muted}" FontSize="12" TextWrapping="Wrap">
                    <Run Text="Directories recreated: "/><Run Text="{Binding Result.DirectoriesText, Mode=OneWay}"/><Run Text="   ·   secrets deferred (no password): "/><Run Text="{Binding Result.DeferredText, Mode=OneWay}"/>
                </TextBlock>

                <TextBlock Margin="0,4,0,0" Foreground="{StaticResource App.Muted}" FontSize="12" TextWrapping="Wrap">
                    <Run Text="Skipped because you trashed them: "/><Run Text="{Binding Result.ExcludedText, Mode=OneWay}"/><Run Text=" (review items only — a kept config or secret is never dropped by the trash)."/>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Result.ExcludedText}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock Margin="0,6,0,0" Foreground="{StaticResource App.Good}" FontSize="12" TextWrapping="Wrap"
                           Text="{Binding Result.RescuedText}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Result.RescuedText}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <Border Background="{StaticResource App.Card}" CornerRadius="6" Padding="12,8" Margin="0,10,0,0"
                        BorderBrush="{StaticResource App.Border}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Total accounting — nothing left uncounted" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Text="{Binding Result.EquationText}" Foreground="{StaticResource App.Muted}"
                                   FontSize="12" Margin="0,3,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <TextBlock Margin="0,10,0,0" Foreground="{StaticResource App.Good}" FontSize="12" TextWrapping="Wrap"
                           Text="{Binding Result.VaultStatus}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Result.VaultStatus}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Failures (only when some) -->
                <StackPanel Margin="0,14,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Result.TopFailures.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Could not copy (reported, never silently dropped)" FontWeight="SemiBold"
                               Foreground="#E8C97A" Margin="0,0,0,6"/>
                    <ItemsControl ItemsSource="{Binding Result.TopFailures}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource App.Card}" CornerRadius="6" Padding="10,6" Margin="0,0,0,4"
                                        BorderBrush="{StaticResource App.Border}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Path}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Reason}" Foreground="{StaticResource App.Muted}" FontSize="11"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
