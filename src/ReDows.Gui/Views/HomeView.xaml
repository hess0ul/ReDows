<UserControl x:Class="ReDows.Gui.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="26,22">
            <TextBlock Text="This PC" FontSize="18" FontWeight="SemiBold"/>
            <TextBlock Text="{Binding Summary}" Foreground="{StaticResource App.Muted}" Margin="0,4,0,18"/>

            <Border Background="#3A2A2A" CornerRadius="6" Padding="12,10" Margin="0,0,0,14">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Error}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding Error}" Foreground="#FF9B9B"/>
            </Border>

            <TextBlock Text="Volumes" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <ItemsControl ItemsSource="{Binding Volumes}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource App.Card}" CornerRadius="6" Padding="14,10" Margin="0,0,0,7"
                                BorderBrush="{StaticResource App.Border}" BorderThickness="1">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border CornerRadius="4" Padding="6,1" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource App.Border}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Scannable}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource App.Good}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Status}" FontSize="11" Foreground="#101014"/>
                                    </Border>
                                    <TextBlock Text="{Binding Mount}" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Detail}" Foreground="{StaticResource App.Muted}" FontSize="12" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="User profiles" FontWeight="SemiBold" Margin="0,18,0,8"/>
            <ItemsControl ItemsSource="{Binding Profiles}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource App.Card}" CornerRadius="6" Padding="14,10" Margin="0,0,0,7"
                                BorderBrush="{StaticResource App.Border}" BorderThickness="1">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding UserName}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding HiveState}" Foreground="{StaticResource App.Muted}"
                                               FontSize="12" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="{Binding RootPath}" Foreground="{StaticResource App.Muted}" FontSize="12" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Margin="0,16,0,0" Foreground="{StaticResource App.Muted}" FontSize="12">
                <Run Text="{Binding NotesCount, Mode=OneWay}"/><Run Text=" discovery note(s) recorded during read-only detection."/>
            </TextBlock>
        </StackPanel>
    </ScrollViewer>
</UserControl>
